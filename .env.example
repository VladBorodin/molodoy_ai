# Application
APP_NAME=Molodoy AI
APP_ENV=development
APP_DEBUG=true

# Database
DATABASE_URL=postgresql+psycopg2://molodoy_user:molodoy_password@localhost:15432/molodoy_ai

# LLM
LLM_PROVIDER=openai_compatible
LLM_API_URL=https://openai.bothub.chat/v1/chat/completions
LLM_API_KEY=replace_me
LLM_MODEL=gpt-4o-mini
LLM_TIMEOUT_SECONDS=60
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=800

# RAG
RAG_MAX_CONTEXT_CHUNKS=3
RAG_MAX_CONTEXT_CHARS=3500

# Chunking
CHUNK_SIZE=900
CHUNK_OVERLAP_SENTENCES=1
CHUNK_MAX_OVERLAP_LENGTH=220
CHUNK_MIN_TAIL_LENGTH=300

# Auth
AUTH_SECRET_KEY=replace_me_with_long_random_secret
AUTH_ALGORITHM=HS256
AUTH_ACCESS_TOKEN_EXPIRE_MINUTES=1440
INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_PASSWORD=admin